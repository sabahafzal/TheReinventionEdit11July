{
  "expo": {
    "name": "The Reinvention Edit",
    "slug": "the-reinvention-edit",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/Logo/TREHvid.png",
    "userInterfaceStyle": "light",
    "scheme": "reinventionedit",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reinventionedit.app",
      "buildNumber": "58",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "SentryDSN": "https://beab71e11cd91a740626271fa86cc054@o4511717414862848.ingest.de.sentry.io/4511717419057232",
        "NSCameraUsageDescription": "The Reinvention Edit uses the camera so you can take or update your profile photo.",
        "NSCalendarsUsageDescription": "The Reinvention Edit exports your roadmap tasks to your calendar to help you stay on schedule.",
        "NSPhotoLibraryUsageDescription": "The Reinvention Edit needs photo library access so you can upload a profile picture or inspiration images.",
        "NSPhotoLibraryAddUsageDescription": "The Reinvention Edit may save images to your photo library when you export or share your plans or reflections.",
        "NSUserNotificationsUsageDescription": "The Reinvention Edit sends reminders to help you stay consistent with your roadmap tasks."
      }
    },

    "android": {
      "package": "com.reinventionedit.app",
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo/TREHvid.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "READ_CALENDAR", "WRITE_CALENDAR",
        "VIBRATE"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/Logo/TREHvid.png",
          "color": "#D6A5D2"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "the-reinvention-edit",
          "project": "react-native"
        }
      ],
      "./plugins/withDumpModulesProvider.cjs"
    ],

    "extra": {
      "eas": {
        "projectId": "b5c6e905-b69f-4f77-8e6d-46a513ae77cd"
      }
    }
  }
}